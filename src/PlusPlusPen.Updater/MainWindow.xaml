<Window x:Class="PlusPlusPen.Updater.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="++PEN Güncelleştirme Merkezi"
        Width="460"
        Height="220"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#FFF3F9FE">
    <Border Margin="16"
            Padding="18"
            CornerRadius="16"
            Background="#F7FFFFFF"
            BorderBrush="#663AA4D8"
            BorderThickness="1.2">
        <StackPanel>
            <TextBlock Text="++PEN Güncelleştirme Merkezi"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="#17344F" />
            <TextBlock x:Name="StatusTextBlock"
                       Margin="0,16,0,0"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Text="Hazırlanıyor..." />
            <TextBlock x:Name="DetailTextBlock"
                       Margin="0,10,0,0"
                       TextWrapping="Wrap"
                       Foreground="#6A17344F"
                       Text="Lütfen bekleyin, güncelleme adımları başlatılıyor." />
            <ProgressBar x:Name="ProgressBar"
                         Margin="0,20,0,0"
                         Height="12"
                         IsIndeterminate="True" />
        </StackPanel>
    </Border>
</Window>
