<Window x:Class="PlusPlusPen.Views.ToolbarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:media="clr-namespace:System.Windows.Media;assembly=PresentationCore"
        Title="++PEN"
        Icon="/Assets/AppIcon.ico"
        Width="820"
        Height="94"
        SizeToContent="WidthAndHeight"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="True"
        Loaded="HandleToolbarLoaded"
        PreviewKeyDown="HandleWindowPreviewKeyDown"
        Topmost="True">
    <Window.Resources>
        <Style x:Key="FloatingToolButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="54" />
            <Setter Property="Height" Value="54" />
            <Setter Property="Margin" Value="0,0,12,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#F8FFFFFF" />
            <Setter Property="BorderBrush" Value="#CC5ABAF0" />
            <Setter Property="BorderThickness" Value="1.3" />
            <Setter Property="Foreground" Value="#14325A" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FFFFFFFF" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#FF7ECFFD" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FFE6F7FF" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#FF36A7EC" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PaletteButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="Transparent"
                                CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#28FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#38D7F3FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="PanelRoot"
            Width="820"
            Height="94"
            Background="Transparent">
        <Border.LayoutTransform>
            <ScaleTransform x:Name="PanelScale" ScaleX="1" ScaleY="1" />
        </Border.LayoutTransform>

        <Border x:Name="DragSurface"
                CornerRadius="24"
                Background="#EDF9FEFF"
                BorderBrush="#FF5DB8ED"
                BorderThickness="1.6"
                Padding="16,12"
                SnapsToDevicePixels="True"
                UseLayoutRounding="True"
                PreviewMouseLeftButtonDown="DragSurface_MouseLeftButtonDown"
                PreviewMouseLeftButtonUp="DragSurface_MouseLeftButtonUp"
                PreviewMouseMove="DragSurface_MouseMove">
            <Border.Effect>
                <DropShadowEffect BlurRadius="18"
                                  ShadowDepth="0"
                                  Color="#55227BB3"
                                  Opacity="0.22" />
            </Border.Effect>

            <Grid Background="Transparent">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="22" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="22" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="22" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Style="{StaticResource FloatingToolButtonStyle}"
                        Width="56"
                        Height="56"
                        Margin="0"
                        Click="SettingsButton_Click"
                        ClickMode="Press"
                        ToolTip="Ayarlar">
                    <Viewbox Width="30" Height="30">
                        <Canvas Width="40" Height="40">
                            <Path Data="M20,6 L23.2,8.1 L27.4,7.2 L29.2,11.2 L33.3,13.1 L32.6,17.3 L34.6,20.6 L32.6,23.8 L33.3,28 L29.2,29.9 L27.4,33.9 L23.2,33 L20,35.1 L16.7,33 L12.5,33.9 L10.8,29.9 L6.7,28 L7.4,23.8 L5.4,20.6 L7.4,17.3 L6.7,13.1 L10.8,11.2 L12.5,7.2 L16.7,8.1 Z"
                                  Fill="#2D79B8" />
                            <Ellipse Width="10.5"
                                     Height="10.5"
                                     Canvas.Left="14.75"
                                     Canvas.Top="15.1"
                                     Fill="#F8FFFFFF" />
                        </Canvas>
                    </Viewbox>
                </Button>

                <Border Grid.Column="2"
                        Width="230"
                        Height="52"
                        Background="#73FFFFFF"
                        BorderBrush="#93D7F3FF"
                        BorderThickness="1"
                        CornerRadius="16"
                        IsHitTestVisible="False">
                    <Grid Margin="16,3,16,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock VerticalAlignment="Center"
                                   FontSize="35"
                                   FontWeight="Bold"
                                   FontStyle="Italic"
                                   Text="##"
                                   Margin="0,-3,10,0">
                            <TextBlock.Foreground>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FF67BCFF" Offset="0" />
                                    <GradientStop Color="#FF2686F6" Offset="1" />
                                </LinearGradientBrush>
                            </TextBlock.Foreground>
                        </TextBlock>
                        <TextBlock Grid.Column="1"
                                   VerticalAlignment="Center"
                                   FontSize="35"
                                   FontWeight="Bold"
                                   Foreground="#102A49"
                                   Text="+PEN" />
                    </Grid>
                </Border>

                <StackPanel Grid.Column="4"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Style="{StaticResource FloatingToolButtonStyle}"
                            Command="{Binding SelectPenCommand}"
                            ClickMode="Press"
                            ToolTip="Kalem">
                        <Viewbox Width="31" Height="31">
                            <Canvas Width="40" Height="40">
                                <Path Data="M6,28 L24,10 C26.5,7.5 30.7,7.5 33.2,10 L35.4,12.2 C37.8,14.6 37.8,18.6 35.4,21 L17.8,38.5 L5.5,34.5 L9.6,22.2 Z"
                                      Fill="#2E97FF"
                                      Stroke="#1757A8"
                                      StrokeThickness="2.1"
                                      StrokeLineJoin="Round" />
                                <Path Data="M23.8,10.1 L29.8,16.1"
                                      Stroke="#A9E8FF"
                                      StrokeThickness="2.4"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round" />
                                <Path Data="M10.2,32.8 L14.6,28.4"
                                      Stroke="#0D3D7C"
                                      StrokeThickness="2.2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round" />
                            </Canvas>
                        </Viewbox>
                    </Button>

                    <Button Style="{StaticResource FloatingToolButtonStyle}"
                            Command="{Binding SelectEraserCommand}"
                            ClickMode="Press"
                            ToolTip="Silgi">
                        <Viewbox Width="31" Height="31">
                            <Canvas Width="40" Height="40">
                                <Path Data="M8.5,25.5 L20.5,13.5 C22.8,11.2 26.4,11.2 28.7,13.5 L34.2,19 C36.6,21.4 36.6,25 34.2,27.4 L26.5,35.2 C24.1,37.6 20.5,37.6 18.1,35.2 L8.5,25.5 Z"
                                      Fill="#D8F2FF"
                                      Stroke="#2B76D1"
                                      StrokeThickness="2.1"
                                      StrokeLineJoin="Round" />
                                <Path Data="M15.2,31.3 L29.2,31.3"
                                      Stroke="#1B5CB3"
                                      StrokeThickness="3.2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round" />
                                <Path Data="M20.2,14.2 L30,24"
                                      Stroke="#B6E9FF"
                                      StrokeThickness="2.2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round" />
                            </Canvas>
                        </Viewbox>
                    </Button>

                    <Button Style="{StaticResource FloatingToolButtonStyle}"
                            Command="{Binding UndoCommand}"
                            ClickMode="Press"
                            ToolTip="Geri al">
                        <Viewbox Width="29" Height="29">
                            <Canvas Width="40" Height="40">
                                <Path Data="M14,12 L6.5,20 L14,28"
                                      Stroke="#2E5F9E"
                                      StrokeThickness="3.8"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round" />
                                <Path Data="M8.5,20 L24.5,20 C29.5,20 33.5,23.5 33.5,28.3"
                                      Stroke="#2E5F9E"
                                      StrokeThickness="3.8"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round" />
                            </Canvas>
                        </Viewbox>
                    </Button>

                    <Button Style="{StaticResource FloatingToolButtonStyle}"
                            Command="{Binding RedoCommand}"
                            ClickMode="Press"
                            ToolTip="Yinele">
                        <Viewbox Width="29" Height="29">
                            <Canvas Width="40" Height="40">
                                <Path Data="M26,12 L33.5,20 L26,28"
                                      Stroke="#2E5F9E"
                                      StrokeThickness="3.8"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round" />
                                <Path Data="M31.5,20 L15.5,20 C10.5,20 6.5,23.5 6.5,28.3"
                                      Stroke="#2E5F9E"
                                      StrokeThickness="3.8"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round" />
                            </Canvas>
                        </Viewbox>
                    </Button>

                    <Button Style="{StaticResource FloatingToolButtonStyle}"
                            Margin="0"
                            Command="{Binding SaveCommand}"
                            ClickMode="Press"
                            ToolTip="Kaydet">
                        <Viewbox Width="29" Height="29">
                            <Canvas Width="40" Height="40">
                                <Path Data="M9,7 L28,7 L33,12 L33,33 L9,33 Z"
                                      Fill="#E6F5FF"
                                      Stroke="#2E5F9E"
                                      StrokeThickness="2.4"
                                      StrokeLineJoin="Round" />
                                <Path Data="M13,7 L13,16 L27,16 L27,7"
                                      Stroke="#2E5F9E"
                                      StrokeThickness="2.4"
                                      StrokeLineJoin="Round" />
                                <Rectangle Width="12"
                                           Height="7"
                                           Canvas.Left="14"
                                           Canvas.Top="22"
                                           RadiusX="1.8"
                                           RadiusY="1.8"
                                           Fill="#78C7FF" />
                                <Rectangle Width="5"
                                           Height="5"
                                           Canvas.Left="23.5"
                                           Canvas.Top="9.2"
                                           Fill="#2E5F9E" />
                            </Canvas>
                        </Viewbox>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Column="6"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Style="{StaticResource PaletteButtonStyle}"
                            Command="{Binding SelectColorCommand}"
                            CommandParameter="{x:Static media:Colors.Black}"
                            ClickMode="Press"
                            ToolTip="Siyah">
                        <Grid>
                            <Ellipse Width="20" Height="20" Fill="#202431" />
                            <Ellipse Width="28" Height="28"
                                     Stroke="#FF68BEF8"
                                     StrokeThickness="2"
                                     Visibility="Collapsed">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsBlackSelected}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource PaletteButtonStyle}"
                            Command="{Binding SelectColorCommand}"
                            CommandParameter="{x:Static media:Colors.RoyalBlue}"
                            ClickMode="Press"
                            ToolTip="Mavi">
                        <Grid>
                            <Ellipse Width="20" Height="20" Fill="#398BFF" />
                            <Ellipse Width="28" Height="28"
                                     Stroke="#FF68BEF8"
                                     StrokeThickness="2"
                                     Visibility="Collapsed">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsBlueSelected}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource PaletteButtonStyle}"
                            Command="{Binding SelectColorCommand}"
                            CommandParameter="{x:Static media:Colors.Red}"
                            ClickMode="Press"
                            ToolTip="Kırmızı">
                        <Grid>
                            <Ellipse Width="20" Height="20" Fill="#F14C53" />
                            <Ellipse Width="28" Height="28"
                                     Stroke="#FF68BEF8"
                                     StrokeThickness="2"
                                     Visibility="Collapsed">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRedSelected}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource PaletteButtonStyle}"
                            Command="{Binding SelectColorCommand}"
                            CommandParameter="{x:Static media:Colors.LimeGreen}"
                            ClickMode="Press"
                            ToolTip="Yeşil">
                        <Grid>
                            <Ellipse Width="20" Height="20" Fill="#53C858" />
                            <Ellipse Width="28" Height="28"
                                     Stroke="#FF68BEF8"
                                     StrokeThickness="2"
                                     Visibility="Collapsed">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsGreenSelected}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource PaletteButtonStyle}"
                            Margin="0"
                            Command="{Binding SelectColorCommand}"
                            CommandParameter="{x:Static media:Colors.Gold}"
                            ClickMode="Press"
                            ToolTip="Sarı">
                        <Grid>
                            <Ellipse Width="20" Height="20" Fill="#FFD759" />
                            <Ellipse Width="28" Height="28"
                                     Stroke="#FF68BEF8"
                                     StrokeThickness="2"
                                     Visibility="Collapsed">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsYellowSelected}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                        </Grid>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Border>
</Window>
