<Window x:Class="PlusPlusPen.Views.ToolbarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:PlusPlusPen.Models"
        Title="++PEN"
        Width="152"
        Height="82"
        SizeToContent="WidthAndHeight"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="True"
        Topmost="True">
    <Window.Resources>
        <Style x:Key="MiniToolButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="20" />
            <Setter Property="Margin" Value="1" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#F6FFFFFF" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource PanelTextBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FFFFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.76" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PenButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Margin" Value="0,0,3,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#F6FFFFFF" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource PanelTextBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsPenActive}" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource PanelActiveGreenBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#FFFFFFFF" />
                            </DataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FFFFFFFF" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="IsPressed" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Root" Property="Opacity" Value="0.76" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EraserButtonStyle" TargetType="Button" BasedOn="{StaticResource MiniToolButtonStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEraserActive}" Value="True">
                    <Setter Property="Background" Value="{StaticResource PanelActiveGreenBrush}" />
                    <Setter Property="BorderBrush" Value="#FFFFFFFF" />
                    <Setter Property="Foreground" Value="White" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border x:Name="PanelRoot"
            Width="142"
            Background="{StaticResource PanelBlueBrush}"
            BorderBrush="{StaticResource PanelBorderBrush}"
            BorderThickness="2"
            CornerRadius="2"
            Padding="2">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="22" />
                <RowDefinition Height="22" />
                <RowDefinition Height="20" />
            </Grid.RowDefinitions>

            <Button x:Name="TitleDragArea"
                    Grid.Row="0"
                    Content="++PEN"
                    Background="#F2FFFFFF"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1"
                    Cursor="SizeAll"
                    FontSize="16"
                    FontWeight="Black"
                    Foreground="{StaticResource PanelTextBrush}"
                    AutomationProperties.Name="++PEN Ayarlar"
                    AutomationProperties.HelpText="Ayarlar" />

            <Grid Grid.Row="1" Grid.RowSpan="2" Margin="0,2,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="36" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="22" />
                    <RowDefinition Height="18" />
                </Grid.RowDefinitions>

                <Button Grid.Row="0"
                        Grid.RowSpan="2"
                        Grid.Column="0"
                        Command="{Binding SelectPenCommand}"
                        Style="{StaticResource PenButtonStyle}"
                        ToolTip="Kalem">
                    <Canvas Width="16" Height="16">
                        <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M2,13 L4,15 L13,6 L10,3 Z" />
                        <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.2"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Data="M9.8,3.2 L12.3,5.7" />
                    </Canvas>
                </Button>

                <UniformGrid Grid.Row="0" Grid.Column="1" Columns="4">
                    <Button Command="{Binding SelectEraserCommand}"
                            Style="{StaticResource EraserButtonStyle}"
                            ToolTip="Silgi">
                        <Canvas Width="13" Height="13">
                            <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  Data="M2,8 L6.8,3.2 C7.2,2.8 7.8,2.8 8.2,3.2 L11,6 C11.4,6.4 11.4,7 11,7.4 L6.2,12.2 L2.8,12.2 C2.3,12.2 2,11.9 2,11.4 Z" />
                            <Line X1="5.8" Y1="11.1" X2="11.2" Y2="11.1"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.1"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round" />
                        </Canvas>
                    </Button>
                    <Button Command="{Binding UndoCommand}"
                            Style="{StaticResource MiniToolButtonStyle}"
                            ToolTip="Geri al">
                        <Path Width="12" Height="12"
                              Stretch="Uniform"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M5,2 L1,6 L5,10 L5,7 C8.5,7 10,8.4 11,10 C10.8,5.6 8.3,4 5,4 Z" />
                    </Button>
                    <Button Command="{Binding RedoCommand}"
                            Style="{StaticResource MiniToolButtonStyle}"
                            ToolTip="Yinele">
                        <Path Width="12" Height="12"
                              Stretch="Uniform"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M7,2 L11,6 L7,10 L7,7 C3.5,7 2,8.4 1,10 C1.2,5.6 3.7,4 7,4 Z" />
                    </Button>
                    <Button Command="{Binding SaveCommand}"
                            Style="{StaticResource MiniToolButtonStyle}"
                            ToolTip="Kaydet">
                        <Canvas Width="12" Height="12">
                            <Rectangle Width="9" Height="9" RadiusX="1" RadiusY="1"
                                       Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                       StrokeThickness="1.1" />
                            <Rectangle Width="4" Height="2" Canvas.Left="2.5" Canvas.Top="1.4"
                                       Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                            <Rectangle Width="3.2" Height="2.2" Canvas.Left="3" Canvas.Top="6.1"
                                       Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                       StrokeThickness="0.9" />
                        </Canvas>
                    </Button>
                </UniformGrid>

                <ItemsControl Grid.Row="1" Grid.Column="1" ItemsSource="{Binding Palette}" Margin="0,2,0,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="5" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:PaletteColorModel}">
                            <Button Width="18"
                                    Height="14"
                                    Margin="1,0"
                                    Padding="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Command="{Binding DataContext.SelectColorCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding Color}"
                                    ToolTip="{Binding Name}">
                                <Ellipse Width="10"
                                         Height="10"
                                         Stroke="{StaticResource PanelBorderBrush}"
                                         StrokeThickness="0.8">
                                    <Ellipse.Fill>
                                        <SolidColorBrush Color="{Binding Color}" />
                                    </Ellipse.Fill>
                                </Ellipse>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Grid>
    </Border>
</Window>
